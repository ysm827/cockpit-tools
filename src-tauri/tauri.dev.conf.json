{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cockpit Tools Dev",
  "identifier": "com.jlcodes.cockpit-tools.dev",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cockpit Tools Dev",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "resizable": true
      },
      {
        "label": "floating-card",
        "title": "Cockpit Tools Dev",
        "create": false,
        "width": 250,
        "height": 290,
        "minWidth": 250,
        "minHeight": 290,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "macOS": {
      "bundleName": "Cockpit Tools Dev",
      "infoPlist": "Info.dev.plist"
    }
  }
}
