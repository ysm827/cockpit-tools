{
  "packageId": "github-copilot",
  "platformId": "github-copilot",
  "apiVersion": 1,
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-github-copilot-adapter",
    "macosEntry": "adapter/macos/cockpit-github-copilot-adapter",
    "windowsEntry": "adapter/windows/cockpit-github-copilot-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-github-copilot-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.restorePendingListener",
      "switch.inject",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "switch",
    "quota",
    "runtime",
    "instances"
  ],
  "contributions": {
    "platforms": [
      {
        "id": "github-copilot",
        "label": "GitHub Copilot",
        "labelKey": "nav.githubCopilot",
        "iconKey": "github-copilot",
        "page": "github-copilot"
      }
    ],
    "dataPaths": [
      "github_copilot_accounts.json",
      "github_copilot_accounts",
      "github_copilot_instances.json"
    ],
    "localStorageKeys": [
      "agtools.github_copilot.accounts.cache",
      "agtools.github_copilot.current_account_id",
      "agtools.github_copilot.flow_notice_collapsed",
      "agtools.github_copilot.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
