{
  "id": "codebuddy_cn",
  "platformId": "codebuddy_cn",
  "version": "0.26.7",
  "apiVersion": 1,
  "minCoreVersion": "0.26.5",
  "displayName": "CodeBuddy CN",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-codebuddy-cn-adapter",
    "macosEntry": "adapter/macos/cockpit-codebuddy-cn-adapter",
    "windowsEntry": "adapter/windows/cockpit-codebuddy-cn-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-codebuddy-cn-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.syncToWorkbuddy",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.restorePendingListener",
      "switch.inject",
      "switch.injectDefaultProfile",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "tokenImport",
    "localImport",
    "switch",
    "quota",
    "runtime",
    "instances",
    "sync"
  ],
  "changelog": [
    {
      "version": "0.26.7",
      "date": "2026-06-23",
      "notes": [
        "CodeBuddy CN account overview, multi-instance tabs, OAuth, token import, local import, switching, quota refresh, WorkBuddy sync, launch commands, and page interactions are now supplied by the CodeBuddy CN platform package.",
        "Core Shell keeps only CodeBuddy CN platform lifecycle controls, runtime gate, Host API, and adapter runner."
      ]
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "codebuddy_cn",
        "label": "CodeBuddy CN",
        "labelKey": "nav.codebuddyCn",
        "iconKey": "codebuddy_cn",
        "page": "codebuddy-cn"
      }
    ],
    "dataPaths": [
      "codebuddy_cn_accounts.json",
      "codebuddy_cn_accounts",
      "codebuddy_cn_instances.json"
    ],
    "localStorageKeys": [
      "agtools.codebuddycn.accounts.cache",
      "agtools.codebuddycn.current_account_id",
      "agtools.codebuddycn.flow_notice_collapsed",
      "agtools.codebuddycn.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
