{
  "id": "gemini",
  "platformId": "gemini",
  "version": "0.26.7",
  "apiVersion": 1,
  "minCoreVersion": "0.26.5",
  "displayName": "Gemini Cli",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-gemini-adapter",
    "macosEntry": "adapter/macos/cockpit-gemini-adapter",
    "windowsEntry": "adapter/windows/cockpit-gemini-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-gemini-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.importJson",
      "accounts.importLocal",
      "accounts.addToken",
      "accounts.export",
      "accounts.indexPath",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.updateTags",
      "quota.alertPayload",
      "oauth.start",
      "oauth.complete",
      "oauth.cancel",
      "oauth.submitCallbackUrl",
      "oauth.restorePendingListener",
      "switch.inject",
      "switch.injectDefaultProfile",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "instance.getLaunchCommand",
      "instance.executeLaunchCommand",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "switch",
    "quota",
    "runtime",
    "instances"
  ],
  "changelog": [
    {
      "version": "0.26.7",
      "date": "2026-06-23",
      "notes": [
        "Gemini Cli account overview, multi-instance tabs, OAuth, token import, switching, quota refresh, launch commands, and page interactions are now supplied by the Gemini platform package.",
        "Core Shell keeps only Gemini platform lifecycle controls, runtime gate, Host API, and adapter runner."
      ]
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "gemini",
        "label": "Gemini Cli",
        "labelKey": "nav.gemini",
        "iconKey": "gemini",
        "page": "gemini"
      }
    ],
    "dataPaths": [
      "gemini_accounts.json",
      "gemini_accounts",
      "gemini_instances.json",
      "gemini_oauth_pending.json"
    ],
    "localStorageKeys": [
      "agtools.gemini.accounts.cache",
      "agtools.gemini.current_account_id",
      "agtools.gemini.flow_notice_collapsed",
      "agtools.gemini.instances.cache"
    ],
    "nativeBoundaries": []
  }
}
